    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "expr = sympy.sin(x * y) * sympy.cos(x / 2)\n",
        "expr"
      ],
      "id": "5a7ccf92",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
