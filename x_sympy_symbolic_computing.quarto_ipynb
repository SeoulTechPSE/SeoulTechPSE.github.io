      ],
      "id": "f4dcca5e",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "sympy.integrate(expr, x)"
      ],
      "id": "4a4ed0d9",
      "execution_count": null,
      "outputs": []
    },
