      ],
      "id": "8955d0b7",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "sympy.cancel(expr3)"
      ],
      "id": "99c1a460",
      "execution_count": null,
      "outputs": []
    },
