      ],
      "id": "84804065",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "sympy.cancel(expr3)"
      ],
      "id": "202a5543",
      "execution_count": null,
      "outputs": []
    },
