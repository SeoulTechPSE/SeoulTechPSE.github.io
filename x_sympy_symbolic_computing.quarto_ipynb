      ],
      "id": "6169d433"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "d = sympy.Derivative(sympy.exp(sympy.cos(x)), x)\n",
        "d"
      ],
      "id": "78ed9532",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
