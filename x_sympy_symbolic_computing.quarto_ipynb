      "source": [
        "---\n"
      ],
      "id": "87fc7be4"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "d = sympy.Derivative(sympy.exp(sympy.cos(x)), x)\n",
        "d"
      ],
      "id": "e2a996a7",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
