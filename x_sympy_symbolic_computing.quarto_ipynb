      "metadata": {},
      "source": [
        "expr.args[2]"
      ],
      "id": "fc648345",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "expr.args[2].args"
      ],
