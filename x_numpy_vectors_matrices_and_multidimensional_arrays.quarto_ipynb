      ],
      "id": "81cd199f",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "---"
      ],
      "id": "70ae033f"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "data = np.random.randn(1, 2, 3, 4, 5)"
      ],
      "id": "b2bc8194",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
