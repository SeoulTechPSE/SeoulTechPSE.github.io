      ],
      "id": "d0fcae19"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "data = np.random.randn(1, 2, 3, 4, 5)"
      ],
      "id": "fb8de760",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
